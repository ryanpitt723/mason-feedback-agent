# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address (must be a verified domain in Resend)
EMAIL_FROM=feedback@yourdomain.com

# Where to send the weekly feedback email (your email)
EMAIL_TO=ryan@yourdomain.com

# Secret used to authenticate Vercel Cron requests — set this in Vercel project settings
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
